# Alert filtering
REGION=*                    # specific city name, or * for all
INCLUDE_TEST_ALERTS=false   # set true to see drills

# Polling
POLL_INTERVAL=1.0           # seconds

# Optional MQTT (leave MQTT_HOST empty to disable)
MQTT_HOST=
MQTT_PORT=1883
MQTT_USER=
MQTT_PASS=
MQTT_TOPIC=/redalert

# Optional Apprise notifications (space-separated URLs)
# See: https://github.com/caronc/apprise
NOTIFIERS=

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
